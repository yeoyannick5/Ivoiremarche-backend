# =============================================
#  IvoireMarché — Variables d'environnement
# =============================================

# Serveur
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ivoiremarche?schema=public"

# JWT
JWT_SECRET=change_this_secret_key_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# =============================================
#  Mobile Money — Clés API
# =============================================

# Orange Money CI (https://developer.orange.com)
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/ci/v1
ORANGE_MONEY_CLIENT_ID=your_orange_client_id
ORANGE_MONEY_CLIENT_SECRET=your_orange_client_secret
ORANGE_MONEY_MERCHANT_KEY=your_merchant_key

# Wave CI (https://developer.wave.com)
WAVE_BASE_URL=https://api.wave.com/v1
WAVE_API_KEY=your_wave_api_key

# MTN MoMo CI (https://momodeveloper.mtn.com)
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_API_USER=your_mtn_api_user
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_ENVIRONMENT=sandbox

# Simulation (true = pas de vrais appels API)
MOBILE_MONEY_MOCK=true
